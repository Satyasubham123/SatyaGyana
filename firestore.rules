rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🚀 1. PUBLIC CONTENT (Courses, Settings, Founders)
    // Anyone can read this data to display on the website, but nobody can write to it from the frontend.
    // (You will update courses directly from the Firebase Console or an Admin Panel)
    
    match /settings/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /founders/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /founder/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
      
      match /sections/{sectionId} {
        allow read: if true;
        allow write: if false;
        
        match /playlists/{playlistId} {
          allow read: if true;
          allow write: if false;

          match /lessons/{lessonId} {
            allow read: if true;
            allow write: if false;
          }
        }
      }

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if false;

        match /lessons/{lessonId} {
          allow read: if true;
          allow write: if false;
        }

        match /quizzes/{quizId} {
          allow read: if true;
          allow write: if false;
        }
      }
    }

    // 🚀 2. HYBRID USER DATA (Gamification, Profiles, Progress)
    // Because Python handles the strict security (Passwords/Emails), 
    // we open these specific paths so the React frontend can sync XP, Badges, and AI Chats.
    
    match /users/{userId} {
      allow read, write: if true;

      match /signals/{signalId} {
        allow read, write: if true;
      }
    }

    match /userProgress/{progressId} {
      allow read, write: if true;
    }

    match /userHistory/{historyId} {
      allow read, write: if true;
    }

    match /quizAttempts/{attemptId} {
      allow read, write: if true;
    }

    match /aiConversations/{conversationId} {
      allow read, write: if true;
    }

    match /flashcards/{flashcardSetId} {
      allow read, write: if true;
    }

    match /submissions/{submissionId} {
      allow read, write: if true;
    }
    
    match /ai_global_cache/{document=**} {
      allow read, write: if true;
    }

    // 🚀 3. STRICT LOCKDOWN
    // Anything related to payments or unknown documents is strictly denied.
    
    match /payments/{paymentId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}