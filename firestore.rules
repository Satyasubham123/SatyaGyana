rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Allow ANYONE (including guests) to read the founder profiles
    match /founders/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /founder/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Allow anyone to view courses so guests can see the curriculum
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /sections/{sectionId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        match /playlists/{playlistId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
    }

    // 3. Keep user profiles protected (Only the logged-in owner can read/write their own profile)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Fallback safeguard for any other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}