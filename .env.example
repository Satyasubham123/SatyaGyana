# Server-side Gemini API key. Keep this secret and never commit a real value.
GEMINI_API_KEY=

# Browser-side Gemini key used by the current Firebase Hosting build.
# Restrict this key by HTTP referrer in Google Cloud before production use.
VITE_GEMINI_API_KEY=

# Razorpay keys. The secret key must exist only in server environments.
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public URL where the app is hosted.
APP_URL=http://localhost:3000
